      "item": [
        {
          "name": "Register Farmer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"farmer_test\",\n  \"email\": \"farmer_test@fellahconnect.com\",\n  \"password\": \"password123\",\n  \"role\": \"farmer\",\n  \"firstName\": \"Ahmed\",\n  \"lastName\": \"Benali\",\n  \"phone\": \"+212612345678\",\n  \"city\": \"Casablanca\",\n  \"region\": \"Casablanca-Settat\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
